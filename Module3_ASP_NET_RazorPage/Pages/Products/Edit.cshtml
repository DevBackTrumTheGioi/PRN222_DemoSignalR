@page
@model Module3_ASP_NET_RazorPage.Pages.Products.EditModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2>Edit Product</h2>

<div asp-validation-summary="ModelOnly" style="color:red;"></div>

<form method="post">
    <input asp-for="Product.ProductId" type="hidden" />
    
    <div>
        <label asp-for="Product.ProductName"></label>
        <input asp-for="Product.ProductName" />
        <span asp-validation-for="Product.ProductName" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.UnitPrice"></label>
        <input asp-for="Product.UnitPrice" />
        <span asp-validation-for="Product.UnitPrice" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.UnitsInStock"></label>
        <input asp-for="Product.UnitsInStock" />
        <span asp-validation-for="Product.UnitsInStock" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.UnitsOnOrder"></label>
        <input asp-for="Product.UnitsOnOrder" />
        <span asp-validation-for="Product.UnitsOnOrder" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.ReorderLevel"></label>
        <input asp-for="Product.ReorderLevel" />
        <span asp-validation-for="Product.ReorderLevel" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.QuantityPerUnit"></label>
        <input asp-for="Product.QuantityPerUnit" />
        <span asp-validation-for="Product.QuantityPerUnit" style="color:red;"></span>
    </div>
    
    <div>
        <label asp-for="Product.Discontinued"></label>
        <input asp-for="Product.Discontinued" type="checkbox" />
        <span asp-validation-for="Product.Discontinued" style="color:red;"></span>
    </div>
    
    <div>
        <button type="submit">Save</button>
        <a href="/Products">Back to List</a>
    </div>
</form>
